# 🌐 إعدادات خادم الباكيند
PORT=5000

# 🔑 المفتاح السري لتشفير الـ JWT (اكتب أي نص عشوائي قوي هنا)
JWT_SECRET=your_jwt_secret_here

# 🧠 توكن الذكاء الاصطناعي الخاص بـ Hugging Face
HF_TOKEN=your_huggingface_token_here

# 💻 رابط الواجهة الأمامية للسماح بعبور البيانات (CORS)
FRONTEND_URL=http://localhost:5173