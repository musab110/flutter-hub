{
  "name": "flutter-ai-mentor",
  "version": "1.0.0",
  "description": "Flutter Mastery Hub - AI Mentor",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev:server": "nodemon backend/backend/server.js",
    "dev:client": "npm run dev --prefix frontend",
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"bgBlue.bold,bgMagenta.bold\" --kill-others \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.14",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^12.35.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "mongoose": "^8.2.1",
    "openai": "^6.27.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}